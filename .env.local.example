# Copy to .env.local and fill in. Used by /api/contact (lead form).

# Resend API key — sign up at https://resend.com, create an API key.
RESEND_API_KEY=

# Optional. Once you verify thirdspacesmarketing.com in Resend, set a branded
# sender, e.g. "Third Spaces Leads <leads@thirdspacesmarketing.com>".
# Until then the route falls back to Resend's shared onboarding@resend.dev.
# FROM_EMAIL=
